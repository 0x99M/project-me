# Token from @BotFather. Secret — never commit the real value.
TELEGRAM_BOT_TOKEN=123456789:AA...

# Comma-separated numeric Telegram user IDs allowed to use the bot.
# Anything from anyone else is ignored. Must be non-empty or the bot refuses to start.
# To find your ID: start the bot with a placeholder here, message it, and read the
# "denied" log line — it prints the sender's ID.
TELEGRAM_ALLOWED_USER_IDS=123456789
